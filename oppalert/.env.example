# Database (PostgreSQL — use Neon.tech or Supabase for free tier)
DATABASE_URL=postgresql://user:password@host:5432/oppalert

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this

# Stripe (get from stripe.com dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Email via Resend (resend.com — free tier: 3000 emails/month)
RESEND_API_KEY=re_...
EMAIL_FROM=alerts@oppalert.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# AI Assistant (OppBot) — get your key at console.groq.com
GROQ_API_KEY=gsk_...
